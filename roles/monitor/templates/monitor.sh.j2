#!/usr/bin/env bash

####  CONFIGURATION  ####

# Path to the persisted journal cursor file
CURSOR_FILE="{{ monitor_cursor_file }}"
# Email recipient address
LOG_MONITOR_EMAIL_TO="{{ monitor_email_to }}"
# Email from address
LOG_MONITOR_EMAIL_FROM="{{ email_username }}"
# Hostname for email subject
LOG_MONITOR_HOSTNAME="{{ ansible_facts['hostname'] }}"
# Log file path
LOG_FILE="{{ tesseract_log_file }}"
# Dry run flag to test the script without sending emails
DRY_RUN="false"

# Function to log messages to the log file
function log()
{
  if [ "${LOG_FILE}" != "" ]; then
    echo "$(date '+%F %T.%3N') ${1}" >> "$LOG_FILE"
  fi
}

# Function to exit the script with an error message
function error_exit()
{
  echo "ERROR: ${1:-"Unknown Error"}"
  log "ERROR: ${1:-"Unknown Error"}"
  exit 1
}

# Check if the script is running as root
if [[ $EUID -ne 0 ]]; then
  error_exit "Script $0 must be run as root."
fi

# Display usage information if -h or --help option is provided
if [ "$1" == "-h" ] || [ "$1" == "--help" ]; then
  echo "Usage: $(basename "$0") [-d|--dry]"
  exit 0
fi

####  MAIN CODE  ####

# Check if -d or --dry option is provided to enable dry run
if [ "$1" == "-d" ] || [ "$1" == "--dry" ]; then
  DRY_RUN="true"
  shift
  log "INFO: Dry run enabled."
fi

log "INFO: Checking journal for new errors."

# Fetch error entries since the last saved cursor position
if [ -f "$CURSOR_FILE" ]; then
  OUTPUT=$(journalctl -p err --after-cursor "$(cat "$CURSOR_FILE")" --show-cursor --no-pager 2>/dev/null)
else
  log "INFO: No cursor file found. Processing all errors since boot."
  OUTPUT=$(journalctl -p err --show-cursor --no-pager 2>/dev/null)
fi

# Extract and persist the new cursor position
NEW_CURSOR=$(echo "$OUTPUT" | grep "^-- cursor:" | tail -n1 | sed 's/^-- cursor: //')
if [ -n "$NEW_CURSOR" ]; then
  echo "$NEW_CURSOR" > "$CURSOR_FILE"
fi

# Strip the cursor line to get only error log entries
ERRORS=$(echo "$OUTPUT" | grep -v "^-- cursor:")
{% if monitor_exclude_patterns | length > 0 %}

# Filter out known noise using configured exclusion patterns
ERRORS=$(echo "$ERRORS" | grep -vE "{{ monitor_exclude_patterns | join('|') }}")
{% endif %}

if [ -n "$ERRORS" ]; then
  log "INFO: Errors found. Sending email to ${LOG_MONITOR_EMAIL_TO}."
  if [ "${DRY_RUN}" == "true" ]; then
    log "INFO: Dry run enabled. Skipping email."
  else
    {
      echo "To: ${LOG_MONITOR_EMAIL_TO}"
      echo "From: ${LOG_MONITOR_EMAIL_FROM}"
      echo "Subject: [${LOG_MONITOR_HOSTNAME}] System errors detected"
      echo ""
      echo "The following errors were detected on ${LOG_MONITOR_HOSTNAME}:"
      echo ""
      echo "${ERRORS}"
    } | msmtp "${LOG_MONITOR_EMAIL_TO}"
    log "INFO: Email sent."
  fi
else
  log "INFO: No errors found."
fi
